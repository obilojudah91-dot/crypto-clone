NODE_ENV=development
PORT=3000

# Must be a long random string (keep private). Used to sign auth cookies (JWT).
JWT_SECRET=change_me_to_a_long_random_string

# Admin notifications (no wallet seed phrases; only public events like wallet addresses and order status).
ADMIN_EMAIL=admin@example.com

# SMTP settings (optional). If missing, notifications are logged to console.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=your_smtp_from_address

# If your frontend runs on a different origin, set it here.
# Example: CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=
